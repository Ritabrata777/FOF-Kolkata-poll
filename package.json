{
  "name": "live-event-poll",
  "version": "0.1.0",
  "private": true,
  "description": "Realtime event audience interaction MVP with live chat, reactions, QR join, and polls.",
  "type": "module",
  "main": "server.ts",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "tsx server.ts",
    "build": "vite build",
    "check": "tsc --noEmit",
    "firebase:login": "npx --yes firebase-tools login",
    "firebase:env": "node scripts/writeFirebaseEnv.mjs",
    "deploy": "npm run build && npx --yes firebase-tools deploy"
  },
  "dependencies": {
    "express": "^4.19.2",
    "firebase": "^12.15.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  }
}
